<?xml version="1.0"?>
<Container version="2">
  <Name>Weather App</Name>
  <Repository>ghcr.io/aleksgain/weather-project:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/aleksgain/weather-project/issues</Support>
  <Project>https://github.com/aleksgain/weather-project</Project>
  <Overview>A self-hosted weather dashboard with multi-source forecasts and runtime configuration via environment variables.</Overview>
  <Category>Productivity: HomeAutomation:</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/aleksgain/weather-project/master/unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/aleksgain/weather-project/master/public/favicon.png</Icon>
  <Config Name="WebUI Port" Target="80" Default="8080" Mode="tcp" Description="Container web port" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="OPENMETEO_ENABLED" Target="OPENMETEO_ENABLED" Default="true" Mode="" Description="Enable Open-Meteo source (no API key required)" Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
  <Config Name="OPENWEATHER_ENABLED" Target="OPENWEATHER_ENABLED" Default="false" Mode="" Description="Enable OpenWeatherMap source" Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="OPENWEATHER_API_KEY" Target="OPENWEATHER_API_KEY" Default="" Mode="" Description="OpenWeatherMap API key" Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="WEATHERAPI_ENABLED" Target="WEATHERAPI_ENABLED" Default="false" Mode="" Description="Enable WeatherAPI source" Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="WEATHERAPI_KEY" Target="WEATHERAPI_KEY" Default="" Mode="" Description="WeatherAPI key" Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="NWS_ENABLED" Target="NWS_ENABLED" Default="false" Mode="" Description="Enable US National Weather Service source" Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="SHOW_SOURCES" Target="SHOW_SOURCES" Default="false" Mode="" Description="Show debug source-attribution badge in UI" Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="DEFAULT_LOCATION_NAME" Target="DEFAULT_LOCATION_NAME" Default="New York" Mode="" Description="Fallback location name when geolocation is denied" Type="Variable" Display="always" Required="false" Mask="false">New York</Config>
  <Config Name="DEFAULT_LAT" Target="DEFAULT_LAT" Default="40.7128" Mode="" Description="Fallback location latitude" Type="Variable" Display="always" Required="false" Mask="false">40.7128</Config>
  <Config Name="DEFAULT_LON" Target="DEFAULT_LON" Default="-74.0060" Mode="" Description="Fallback location longitude" Type="Variable" Display="always" Required="false" Mask="false">-74.0060</Config>
</Container>
